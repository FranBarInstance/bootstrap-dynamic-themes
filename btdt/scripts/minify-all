#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MINIFY_PY="$SCRIPT_DIR/minify.py"
VENV_DIR="$SCRIPT_DIR/.venv"

NORMAL_DIRS=(
  "$SCRIPT_DIR/../css"
  "$SCRIPT_DIR/../js"
  "$SCRIPT_DIR/../themes/colors"
  "$SCRIPT_DIR/../themes/fonts"
  "$SCRIPT_DIR/../themes/modes"
  "$SCRIPT_DIR/../themes/styles"
)

PRESET_DIRS=(
  "$SCRIPT_DIR/../themes/preset"
)

source "$VENV_DIR/bin/activate"

for dir in "${NORMAL_DIRS[@]}"; do
  python "$MINIFY_PY" normal "$dir"
done

for dir in "${PRESET_DIRS[@]}"; do
  python "$MINIFY_PY" preset "$dir"
done
